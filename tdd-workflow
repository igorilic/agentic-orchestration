      → tdd-developer (Sonnet)  RED→GREEN→REFACTOR per step
      → qa (Haiku)              runs affected tests
      → reviewer (Sonnet)       presents findings to you
      → you triage              [F]ix / [T]ech debt / [I]gnore
      → max 3 fix loops         then next step

  COPILOT CLI USAGE

    Copilot CLI agents mirror Claude Code agents with .agent.md format.
    Installed to ~/.copilot/agents/ (or $COPILOT_HOME/agents/).

    Interactive:
      copilot                               # start session
      /agent                                # pick from agent list

    Direct:
      copilot --agent=architect --prompt "Plan JWT auth feature"
      copilot --agent=tdd-developer --prompt "Step 1 of PROJ-123-todo.md"
      copilot --agent=qa --prompt "Verify the changes"
      copilot --agent=reviewer --prompt "Review the changes"
      copilot --agent=troubleshooter --prompt "Investigate PROJ-456"

    Automatic:
      Copilot infers the right agent from your prompt if the
      description matches. "Plan a new feature" → architect.
      "Run the tests" → qa.

    Shared context:
      AGENTS.md and .github/copilot-instructions.md are read by
      both Claude Code and Copilot CLI automatically.

HELP
}

main() {
  local command="${1:-help}"
  local subcommand="${2:-}"
  local target="${3:-}"

  case "$command" in
    install)
      case "$subcommand" in
        global)
          install_global
          ;;
        project)
          install_project "${target:-.}"
          ;;
        all)
          install_global
          echo ""
          install_project "${target:-.}"
          ;;
        *)
          error "Unknown install target: $subcommand"
          echo "  Use: install global | install project [path] | install all [path]"
          exit 1
          ;;
      esac
      ;;
    detect)
      show_detect "${subcommand:-.}"
      ;;
    status)
      show_status
      ;;
    uninstall)
      case "$subcommand" in
        global)  uninstall_global ;;
        project) uninstall_project "${target:-.}" ;;
        *)
          error "Unknown uninstall target: $subcommand"
          echo "  Use: uninstall global | uninstall project [path]"
          exit 1
          ;;
      esac
      ;;
    help|--help|-h)
      show_help
      ;;
    version|--version|-v)
      echo "tdd-workflow v${VERSION}"
      ;;
    *)
      error "Unknown command: $command"
      show_help
      exit 1
      ;;
  esac
}

main "$@"
