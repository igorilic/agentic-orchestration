# ║                           MAIN                                  ║
# ╚══════════════════════════════════════════════════════════════════╝

show_help() {
  cat << 'EOF'

  demo-pipeline — Simulated pipeline demos

  USAGE
    demo-pipeline <demo>

  DEMOS
    github-feature      GitHub feature pipeline (Claude Code)
    github-issue [ID]   GitHub issue pipeline (Claude Code)
    gitlab-feature      GitLab feature pipeline (Copilot CLI)
    gitlab-incident     GitLab incident pipeline (Copilot CLI)
    error-resume        Error handling & resume flow
    all                 Run all demos in sequence

EOF
}

main() {
  case "${1:-help}" in
    github-feature)  demo_github_feature ;;
    github-issue)    demo_github_issue "${2:-42}" ;;
    gitlab-feature)  demo_gitlab_feature ;;
    gitlab-incident) demo_gitlab_incident ;;
    error-resume)    demo_error_resume ;;
    all)
      demo_github_feature
      pause_for_audience
      demo_github_issue 42
      pause_for_audience
      demo_gitlab_feature
      pause_for_audience
      demo_gitlab_incident
      pause_for_audience
      demo_error_resume
      ;;
    help|--help|-h) show_help ;;
    *) error "Unknown demo: $1"; show_help; exit 1 ;;
  esac
}

main "$@"
