# ║              DEMO 2: GITHUB ISSUE                               ║
# ╚══════════════════════════════════════════════════════════════════╝

demo_github_issue() {
  local issue_id="${1:-42}"
  clear
  echo ""
  echo -e "${BOLD}${CYAN}╔════════════════════════════════════════════════════════╗${NC}"
  echo -e "${BOLD}${CYAN}║     Demo: GitHub Issue Pipeline (Claude Code)         ║${NC}"
  echo -e "${BOLD}${CYAN}╚════════════════════════════════════════════════════════╝${NC}"
  echo ""
  echo -e "  ${DIM}Command: ai-native-workflow run github-issue ${issue_id}${NC}"
  echo -e "  ${DIM}Pipeline: issue → troubleshoot → architect → TDD → PR${NC}"
  echo ""
  pause_for_audience

  # Step 1: Fetch
  pstep 1 "Fetch Issue & Sub-Issues"
  echo ""
  echo -e "  ${BLUE}ℹ${NC} Reading issue #${issue_id}..."
  sleep 1
  echo -e "  ${BOLD}#${issue_id}${NC}: SQL injection vulnerability in query builder"
  echo -e "  ${DIM}Labels: bug, security${NC}"
  echo -e "  ${DIM}State: open${NC}"
  sleep 1
  echo -e "  ${BLUE}ℹ${NC} Found sub-issue references: #43 #44"
  echo -e "  ${DIM}#43: Parameterize WHERE clause inputs${NC}"
  echo -e "  ${DIM}#44: Add input sanitization to ORDER BY${NC}"
  echo ""
  success "Issue context saved: .context/specs/issue-${issue_id}-issue-context.md"
  pause_for_audience

  # Step 2: Troubleshooter
  pstep 2 "Investigation (Troubleshooter)"
  mock_agent "troubleshooter" 4 "
  ${BOLD}${RED}DIAGNOSIS: SQL Injection in Query Builder${NC}

  ${BOLD}Root Cause${NC}:
  User input is concatenated directly into SQL strings in
  \`src/lib/query-builder.ts:47\` and \`src/lib/query-builder.ts:82\`.
  No parameterization or escaping is applied.

  ${BOLD}Affected Files${NC}:
  - src/lib/query-builder.ts (lines 47, 82, 115)
  - src/routes/api/search.ts (passes raw input)

  ${BOLD}Evidence${NC}:
  \`git log --oneline -3 -- src/lib/query-builder.ts\`
  a1b2c3d feat: add dynamic WHERE clause builder
  d4e5f6g feat: add ORDER BY support

  ${BOLD}Fix Approach${NC}:
  1. Parameterize all WHERE clause inputs
  2. Whitelist ORDER BY column names
  3. Add integration tests with injection payloads

  ${DIM}Saved: .context/specs/issue-${issue_id}-bugfix.md${NC}
  ${DIM}Saved: .context/specs/issue-${issue_id}-todo.md${NC}"

  info "Review: .context/specs/issue-${issue_id}-bugfix.md"
  pause_for_audience

  # Step 3: Architect
  pstep 3 "Architecture & Planning"
  mock_agent "architect" 3 "
  ${BOLD}Plan refined: 3 TDD steps${NC}

  ${MAGENTA}Step 1${NC}: Reproduce SQL injection as failing test
    Test: inject \`'; DROP TABLE users; --\` → must not execute
    Files: tests/security/sql-injection.test.ts

  ${MAGENTA}Step 2${NC}: Parameterize WHERE clause
    Test: query uses $1, $2 placeholders, not string concat
    Files: src/lib/query-builder.ts

  ${MAGENTA}Step 3${NC}: Whitelist ORDER BY + sanitize
    Test: reject non-column names, reject SQL keywords
    Files: src/lib/query-builder.ts, src/lib/sanitize.ts"

  info "Review: .context/specs/issue-${issue_id}-todo.md"
  pause_for_audience

  # TDD step 1 (the key one — reproduce the bug)
  pstep "4.1" "TDD: Step 1/3 — Reproduce SQL injection"
  mock_agent "tdd-developer" 3 "
  ${RED}RED${NC}: Failing security test written
    ${DIM}✗ should prevent SQL injection in WHERE clause
    ✗ should prevent SQL injection in ORDER BY
    ✗ should reject payloads with SQL keywords${NC}

  ${BOLD}Bug confirmed:${NC} injection payload executes successfully.

  ${GREEN}GREEN${NC}: Parameterized queries — all 3 passing
    ${DIM}✓ should prevent SQL injection in WHERE clause (5ms)
    ✓ should prevent SQL injection in ORDER BY (3ms)
    ✓ should reject payloads with SQL keywords (2ms)${NC}

  ${DIM}Commits: test(security): reproduce SQL injection, fix(security): parameterize queries${NC}"

  pstep "5.1" "QA: Test Step 1/3"
  mock_agent "qa" 2 "
  ${GREEN}Tests: 3 passed${NC}, 0 failed
  ${DIM}+ 12 existing tests still passing
  Time: 0.45s${NC}"

  pstep "6.1" "Review: Step 1/3"
  mock_agent "reviewer" 2 "
  ${GREEN}🔴 No blocking issues${NC}
  ${GREEN}🟢 SUGGESTION${NC}: Add test for Unicode injection payloads
  ${BOLD}Security fix looks solid.${NC} Parameterization is correct."

  echo -e "  ${DIM}... (Steps 2-3 follow same pattern) ...${NC}"
  pause_for_audience

  # PR
  pstep 7 "Create Pull Request"
  echo ""
  echo -e "  ${GREEN}✓${NC} PR created: ${BOLD}https://github.com/user/repo/pull/45${NC}"
  echo -e "  ${DIM}Title: fix: SQL injection vulnerability in query builder${NC}"
  echo -e "  ${DIM}Closes #${issue_id}, #43, #44${NC}"
  pause_for_audience

  header "Pipeline Wrap-Up"
  echo ""
  echo -e "  ${BOLD}Pipeline${NC}:  github-issue"
  echo -e "  ${BOLD}Issue${NC}:     #${issue_id}"
  echo -e "  ${BOLD}Commits${NC}:   6"
  echo ""
  success "GitHub issue pipeline finished."
  echo ""
}

