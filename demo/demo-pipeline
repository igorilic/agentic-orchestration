#!/usr/bin/env bash
# demo-pipeline — Simulates the ai-native-workflow pipelines with mocked agents.
# Shows the full orchestration flow with realistic delays and output.
#
# Usage:
#   demo-pipeline github-feature        Simulate GitHub feature pipeline
#   demo-pipeline github-issue 42       Simulate GitHub issue pipeline
#   demo-pipeline gitlab-feature        Simulate GitLab feature pipeline
#   demo-pipeline gitlab-incident       Simulate GitLab incident pipeline
#   demo-pipeline all                   Run all demos in sequence

set -euo pipefail

# --- Colors ---
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

# --- Helpers ---
info()    { echo -e "${BLUE}ℹ${NC} $*"; }
success() { echo -e "${GREEN}✓${NC} $*"; }
warn()    { echo -e "${YELLOW}⚠${NC} $*"; }
error()   { echo -e "${RED}✗${NC} $*" >&2; }
header()  { echo -e "\n${BOLD}${CYAN}$*${NC}"; }
pstep()   { echo -e "\n${BOLD}${MAGENTA}▸ Step $1:${NC} $2"; }
dim()     { echo -e "${DIM}  $*${NC}"; }
ask()     { echo -en "${YELLOW}?${NC} $* "; }

# --- Spinner ---
SPINNER_PID=""
spinner_start() {
  local label="${1:-Working}"
  (
    local frames=("⠋" "⠙" "⠹" "⠸" "⠼" "⠴" "⠦" "⠧" "⠇" "⠏")
    local i=0 elapsed=0
    while true; do
      local frame="${frames[$((i % ${#frames[@]}))]}"
      local secs=$((elapsed % 60))
      printf "\r  ${MAGENTA}%s${NC} ${BOLD}%s${NC} ${DIM}(%ss)${NC}  " "$frame" "$label" "$secs"
      sleep 1
      elapsed=$((elapsed + 1))
      i=$((i + 1))
    done
  ) &
  SPINNER_PID=$!
}

spinner_stop() {
  if [ -n "$SPINNER_PID" ] && kill -0 "$SPINNER_PID" 2>/dev/null; then
    kill "$SPINNER_PID" 2>/dev/null
    wait "$SPINNER_PID" 2>/dev/null || true
    printf "\r%80s\r" ""
  fi
  SPINNER_PID=""
}

# --- Mock agent runner ---
mock_agent() {
  local agent="$1"
  local delay="${2:-3}"
  local output="$3"

  header "Running: $agent (Claude Code)"
  dim "Mock mode — simulating agent work"
  echo ""

  spinner_start "$agent"
  sleep "$delay"
  spinner_stop

  echo -e "$output"
  echo ""
  success "$agent completed"
}

mock_agent_copilot() {
  local agent="$1"
  local delay="${2:-3}"
  local output="$3"

  header "Running: $agent (Copilot CLI)"
  dim "Mock mode — simulating agent work"
  echo ""

  spinner_start "$agent"
  sleep "$delay"
  spinner_stop

  echo -e "$output"
  echo ""
  success "$agent completed"
}

pause_for_audience() {
  echo ""
  echo -e "  ${DIM}───────────────────────────────────────${NC}"
  ask "Press Enter to continue..."
  read -r
}

