  ${GREEN}FR-1${NC}: Users can sign up with email + password
  ${GREEN}FR-2${NC}: Users can log in with credentials
  ${GREEN}FR-3${NC}: JWT tokens issued on successful auth
  ${GREEN}FR-4${NC}: Password hashing with bcrypt (cost 12)

  ${YELLOW}AC-1${NC}: Given valid credentials, When POST /auth/login, Then 200 + JWT
  ${YELLOW}AC-2${NC}: Given invalid password, When POST /auth/login, Then 401
  ${YELLOW}AC-3${NC}: Given duplicate email, When POST /auth/signup, Then 409

  ${DIM}Saved: .context/specs/requirements.md${NC}"

  info "Review: .context/specs/requirements.md"
  pause_for_audience

  # Step 2: GitHub Issue
  pstep 2 "Create GitHub Issue"
  echo ""
  echo -e "  ${GREEN}✓${NC} Created issue: ${BOLD}https://github.com/user/repo/issues/15${NC}"
  echo -e "  ${DIM}Title: feat: User Authentication${NC}"
  echo -e "  ${DIM}Labels: feature-request${NC}"
  pause_for_audience

  # Step 3: Architect
  pstep 3 "Architecture & Planning"
  mock_agent "architect" 4 "
  ${BOLD}Plan: 4 TDD steps${NC}

  ${MAGENTA}Step 1${NC}: User model + migration
    Test: user creation, duplicate email check
    Files: src/models/user.ts, src/db/migrations/001_users.sql

  ${MAGENTA}Step 2${NC}: Password hashing service
    Test: hash, verify, cost factor
    Files: src/services/password.ts

  ${MAGENTA}Step 3${NC}: Auth endpoints (signup + login)
    Test: POST /auth/signup, POST /auth/login, error cases
    Files: src/routes/auth.ts, src/middleware/validate.ts

  ${MAGENTA}Step 4${NC}: JWT token service
    Test: sign, verify, expiry, invalid tokens
    Files: src/services/jwt.ts

  ${DIM}Saved: .context/specs/auth-todo.md${NC}"

  info "Review: .context/specs/auth-todo.md"
  pause_for_audience

  # Step 4-6: TDD Loop (show 2 of 4 steps)
  for step_num in 1 2; do
    local step_name
    [ "$step_num" -eq 1 ] && step_name="User model + migration"
    [ "$step_num" -eq 2 ] && step_name="Password hashing service"

    pstep "4.$step_num" "TDD: Step $step_num/4 — $step_name"
    mock_agent "tdd-developer" 3 "
  ${RED}RED${NC}: 3 failing tests written
    ${DIM}✗ should create user with valid email
    ✗ should reject duplicate email
    ✗ should hash password on creation${NC}
  ${GREEN}GREEN${NC}: All 3 tests passing
    ${DIM}✓ should create user with valid email (2ms)
    ✓ should reject duplicate email (3ms)
    ✓ should hash password on creation (45ms)${NC}
  ${BLUE}REFACTOR${NC}: Extracted UserRepository interface
  ${DIM}Commits: test(auth): add user model tests, feat(auth): implement user model${NC}"

    pstep "5.$step_num" "QA: Test Step $step_num/4"
    mock_agent "qa" 2 "
  ${GREEN}Tests: 3 passed${NC}, 0 failed, 0 skipped
  ${DIM}Time: 0.23s
  Coverage: src/models/user.ts — 94%
  Ready for review${NC}"

    pstep "6.$step_num" "Review: Step $step_num/4"
    mock_agent "reviewer" 2 "
  ${GREEN}🟢 SUGGESTION${NC}: Consider adding index on email column
  ${GREEN}🟢 SUGGESTION${NC}: Add JSDoc to UserRepository interface

  ${BOLD}No blocking issues.${NC} Code is clean."

    echo ""
    echo -e "  ${DIM}Triage: [D]one — no issues to fix${NC}"

    if [ "$step_num" -lt 2 ]; then
      pause_for_audience
    fi
  done

  echo ""
  echo -e "  ${DIM}... (Steps 3-4 follow same pattern) ...${NC}"
  pause_for_audience

  # Step 7: PR
  pstep 7 "Create Pull Request"
  echo ""
  echo -e "  ${GREEN}✓${NC} PR created: ${BOLD}https://github.com/user/repo/pull/16${NC}"
  echo -e "  ${DIM}Title: feat: User Authentication${NC}"
  echo -e "  ${DIM}Closes #15${NC}"
  pause_for_audience

  # Finish
  header "Pipeline Wrap-Up"
  echo ""
  echo -e "  ${BOLD}Pipeline${NC}:  github-feature"
  echo -e "  ${BOLD}Commits${NC}:   8"
  echo -e "  ${BOLD}Artifacts${NC}: 3 files"
  echo ""
  success "GitHub feature pipeline finished."
  echo ""
}

