#!/usr/bin/env bash
# ai-native-workflow — CLI for AI-native development workflows
# Installs hooks, skills, agents AND runs multi-agent pipelines.
#
# Usage:
#   ai-native-workflow install global            Install global hooks, skills, settings
#   ai-native-workflow install project [path]    Install project files (auto-detects stack)
#   ai-native-workflow install all [path]        Install both global + project
#   ai-native-workflow run gitlab-feature <ID>   Run GitLab feature pipeline (Copilot + Jira)
#   ai-native-workflow run gitlab-incident <ID>  Run GitLab incident pipeline (Troubleshooter)
#   ai-native-workflow run github-feature [file] Run GitHub feature pipeline (Claude Code)
#   ai-native-workflow run github-issue <ID>     Run GitHub issue fix pipeline (Claude Code)
#   ai-native-workflow run status                Show active pipeline state
#   ai-native-workflow run resume                Resume pipeline from last checkpoint
#
# Flags:
#   --allowed-questions [N]  Let agents ask up to N clarifying questions (default: 3)
#   ai-native-workflow detect [path]             Detect stack without installing
#   ai-native-workflow status                    Show what's installed
#   ai-native-workflow uninstall global          Remove global installation
#   ai-native-workflow uninstall project [path]  Remove project files
#   ai-native-workflow help                      Show this help
#   ai-native-workflow version                   Show version

set -euo pipefail

VERSION="3.0.0"
CLAUDE_DIR="${CLAUDE_HOME:-$HOME/.claude}"
COPILOT_DIR="${COPILOT_HOME:-$HOME/.copilot}"
COPILOT_AGENTS_DIR="$COPILOT_DIR/agents"
COPILOT_SKILLS_DIR="$COPILOT_DIR/skills"
COPILOT_INSTRUCTIONS_FILE="$COPILOT_DIR/copilot-instructions.md"
COPILOT_SETTINGS_FILE="$COPILOT_DIR/settings.json"
BACKUP_SUFFIX=".bak.$(date +%Y%m%d%H%M%S)"
SPEC_DIR="docs/context/specs"
SPRINT_FILE="docs/context/CURRENT_SPRINT.md"
RUNTIME_DIR=".context"
STATE_FILE="${RUNTIME_DIR}/.pipeline-state"
CONTEXT_DIR="$SPEC_DIR"   # backwards-compat alias — drop after one release
ALLOWED_QUESTIONS=0   # 0 = disabled; N = max questions per agent run
LAST_AGENT_OUTPUT=""  # captured after each agent run for question detection
LAST_AGENT_TOOL=""    # "copilot" or "claude" — set by run_*_agent
LAST_AGENT_NAME=""    # agent name — set by run_*_agent
LAST_AGENT_PROMPT=""  # prompt used — set by run_*_agent
AW_DRY_RUN="${AW_DRY_RUN:-0}"   # set to 1 to skip agent invocations (testing / dry-run)
AW_SPEC_ID="${AW_SPEC_ID:-}"    # override spec id (used with AW_DRY_RUN)


# ── Resolve this script's real directory (through symlinks) to locate lib/ ──
_anw_resolve_source() {
  local src="${BASH_SOURCE[0]}"
  local _resolved
  if command -v realpath >/dev/null 2>&1; then
    if _resolved="$(realpath "$src" 2>/dev/null)"; then
      echo "$_resolved"
      return 0
    fi
  fi
  if command -v greadlink >/dev/null 2>&1; then
    if _resolved="$(greadlink -f "$src" 2>/dev/null)"; then
      echo "$_resolved"
      return 0
    fi
  fi
  local _guard=0
  while [ -L "$src" ]; do
    _guard=$((_guard + 1))
    if [ "$_guard" -gt 100 ]; then
      echo "anw: symlink cycle detected resolving ${BASH_SOURCE[0]}" >&2
      exit 1
    fi
    local target
    target="$(readlink "$src")"
    case "$target" in
      /*) src="$target" ;;
      *)  src="$(cd "$(dirname "$src")" && pwd -P)/$target" ;;
    esac
  done
  echo "$src"
}
_ANW_SCRIPT_DIR="$(cd "$(dirname "$(_anw_resolve_source)")" && pwd -P)"
unset -f _anw_resolve_source

# Internal diagnostic: print the resolved script dir and exit *before* loading
# the library, so script-dir resolution can be verified even when lib/ is not
# alongside the script (the script-dir tests copy/symlink the bare file).
if [ "${1:-}" = "__print-script-dir" ]; then
  echo "$_ANW_SCRIPT_DIR"
  exit 0
fi

# ── Load library modules (function definitions; constants above are set) ──
for _anw_mod in common detect pipeline-core pipelines install-global install-project status uninstall help; do
  # shellcheck source=/dev/null
  source "$_ANW_SCRIPT_DIR/lib/${_anw_mod}.sh"
done
unset _anw_mod

# Source confidence CLI helpers if available (write_active_spec,
# emit_step_verdict, build_pr_body).
if [ -f "$_ANW_SCRIPT_DIR/scripts/confidence-cli.sh" ]; then
  # shellcheck source=scripts/confidence-cli.sh
  source "$_ANW_SCRIPT_DIR/scripts/confidence-cli.sh"
fi

main() {
  # --- Parse flags (remove from positional args) ---
  local args=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --allowed-questions=*)
        ALLOWED_QUESTIONS="${1#*=}"
        ;;
      --allowed-questions)
        if [[ "${2:-}" =~ ^[0-9]+$ ]]; then
          ALLOWED_QUESTIONS="$2"
          shift
        else
          ALLOWED_QUESTIONS=3  # default: 3 questions
        fi
        ;;
      *)
        args+=("$1")
        ;;
    esac
    shift
  done

  local command="${args[0]:-help}"
  local subcommand="${args[1]:-}"
  local target="${args[2]:-}"

  case "$command" in
    install)
      case "$subcommand" in
        global)
          install_global
          ;;
        project)
          install_project "${target:-.}"
          ;;
        all)
          install_global
          echo ""
          install_project "${target:-.}"
          ;;
        *)
          error "Unknown install target: $subcommand"
          echo "  Use: install global | install project [path] | install all [path]"
          exit 1
          ;;
      esac
      ;;
    run)
      case "$subcommand" in
        gitlab-feature)
          if [ -z "$target" ]; then
            error "Usage: ai-native-workflow run gitlab-feature <JIRA-ID>"
            exit 1
          fi
          pipeline_gitlab_feature "$target"
          ;;
        gitlab-incident)
          if [ -z "$target" ]; then
            error "Usage: ai-native-workflow run gitlab-incident <JIRA-ID>"
            exit 1
          fi
          pipeline_gitlab_incident "$target"
          ;;
        github-feature)
          pipeline_github_feature "${target:-}"
          ;;
        github-issue)
          if [ -z "$target" ]; then
            error "Usage: ai-native-workflow run github-issue <ISSUE-ID>"
            exit 1
          fi
          pipeline_github_issue "$target"
          ;;
        status)
          pipeline_status
          ;;
        resume)
          pipeline_resume
          ;;
        *)
          error "Unknown run target: $subcommand"
          echo "  Use: run gitlab-feature <ID> | run gitlab-incident <ID> | run github-feature [file]"
          echo "       run github-issue <ID> | run status | run resume"
          exit 1
          ;;
      esac
      ;;
    detect)
      show_detect "${subcommand:-.}"
      ;;
    status)
      show_status
      ;;
    uninstall)
      case "$subcommand" in
        global)  uninstall_global ;;
        project) uninstall_project "${target:-.}" ;;
        *)
          error "Unknown uninstall target: $subcommand"
          echo "  Use: uninstall global | uninstall project [path]"
          exit 1
          ;;
      esac
      ;;
    help|--help|-h)
      show_help
      ;;
    version|--version|-v)
      echo "ai-native-workflow v${VERSION}"
      ;;
    __print-script-dir)
      echo "$_ANW_SCRIPT_DIR"
      exit 0
      ;;
    *)
      error "Unknown command: $command"
      show_help
      exit 1
      ;;
  esac
}

main "$@"
