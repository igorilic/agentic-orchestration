CONTEXT=""

detect_stack() {
  local stack=""
  if compgen -G "$PROJECT_DIR"/*.sln > /dev/null 2>&1 || \
     find "$PROJECT_DIR" -maxdepth 3 -name "*.csproj" -print -quit 2>/dev/null | grep -q . 2>/dev/null; then
