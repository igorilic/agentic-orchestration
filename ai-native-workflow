main() {
  local command="${1:-help}"
  local subcommand="${2:-}"
  local target="${3:-}"

  case "$command" in
    install)
      case "$subcommand" in
        global)
          install_global
          ;;
        project)
          install_project "${target:-.}"
          ;;
        all)
          install_global
          echo ""
          install_project "${target:-.}"
          ;;
        *)
          error "Unknown install target: $subcommand"
          echo "  Use: install global | install project [path] | install all [path]"
          exit 1
          ;;
      esac
      ;;
    run)
      case "$subcommand" in
        gitlab-feature)
          if [ -z "$target" ]; then
            error "Usage: ai-native-workflow run gitlab-feature <JIRA-ID>"
            exit 1
          fi
          pipeline_gitlab_feature "$target"
          ;;
        gitlab-incident)
          if [ -z "$target" ]; then
            error "Usage: ai-native-workflow run gitlab-incident <JIRA-ID>"
            exit 1
          fi
          pipeline_gitlab_incident "$target"
          ;;
        github-feature)
          pipeline_github_feature "${target:-}"
          ;;
        github-issue)
          if [ -z "$target" ]; then
            error "Usage: ai-native-workflow run github-issue <ISSUE-ID>"
            exit 1
          fi
          pipeline_github_issue "$target"
          ;;
        status)
          pipeline_status
          ;;
        resume)
          pipeline_resume
          ;;
        *)
          error "Unknown run target: $subcommand"
          echo "  Use: run gitlab-feature <ID> | run gitlab-incident <ID> | run github-feature [file]"
          echo "       run github-issue <ID> | run status | run resume"
          exit 1
          ;;
      esac
      ;;
    detect)
      show_detect "${subcommand:-.}"
      ;;
    status)
      show_status
      ;;
    uninstall)
      case "$subcommand" in
        global)  uninstall_global ;;
        project) uninstall_project "${target:-.}" ;;
        *)
          error "Unknown uninstall target: $subcommand"
          echo "  Use: uninstall global | uninstall project [path]"
          exit 1
          ;;
      esac
      ;;
    help|--help|-h)
      show_help
      ;;
    version|--version|-v)
      echo "ai-native-workflow v${VERSION}"
      ;;
    *)
      error "Unknown command: $command"
      show_help
      exit 1
      ;;
  esac
}

main "$@"
