#!/usr/bin/env bash
# pipeline — CLI runner for multi-agent pipelines
# Orchestrates agents in sequence with user decision points.
#
# Usage:
#   pipeline gitlab-feature <JIRA-ID>         Run GitLab feature pipeline (Copilot CLI + Jira)
#   pipeline gitlab-incident <JIRA-ID>        Run GitLab incident pipeline (Copilot CLI + Jira)
#   pipeline github-feature [specs-file]      Run GitHub feature pipeline (Claude Code)
#   pipeline status                           Show pipeline state for current project
#   pipeline resume                           Resume pipeline from last completed step
#   pipeline help                             Show this help

set -euo pipefail

VERSION="3.0.0"
CONTEXT_DIR=".context/specs"
STATE_FILE=".context/.pipeline-state"

# --- Colors ---
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

# --- Helpers ---
info()    { echo -e "${BLUE}ℹ${NC} $*"; }
success() { echo -e "${GREEN}✓${NC} $*"; }
warn()    { echo -e "${YELLOW}⚠${NC} $*"; }
error()   { echo -e "${RED}✗${NC} $*" >&2; }
header()  { echo -e "\n${BOLD}${CYAN}═══ $* ═══${NC}"; }
step()    { echo -e "\n${BOLD}${MAGENTA}▸ Step $1:${NC} $2"; }
dim()     { echo -e "${DIM}  $*${NC}"; }
ask()     { echo -en "${YELLOW}?${NC} $* "; }

# --- Platform Detection ---
detect_platform() {
  local project_dir="${1:-.}"
  if [ -f "$project_dir/.gitlab-ci.yml" ] || \
     (git -C "$project_dir" remote -v 2>/dev/null | grep -q gitlab); then
    echo "gitlab"
  else
    echo "github"
  fi
}

# --- CLI Detection ---
require_copilot() {
  if ! command -v copilot &>/dev/null; then
    error "GitHub Copilot CLI not found. Install: https://docs.github.com/en/copilot/github-copilot-in-the-cli"
    exit 1
  fi
}

require_claude() {
  if ! command -v claude &>/dev/null; then
    error "Claude Code CLI not found. Install: npm install -g @anthropic-ai/claude-code"
    exit 1
  fi
}

require_glab() {
  if ! command -v glab &>/dev/null; then
    error "glab CLI not found. Install: brew install glab"
    exit 1
  fi
}

require_gh() {
  if ! command -v gh &>/dev/null; then
    error "gh CLI not found. Install: brew install gh"
    exit 1
  fi
}

# --- State Management ---
save_state() {
  local pipeline="$1" id="$2" current_step="$3" status="$4"
  mkdir -p "$(dirname "$STATE_FILE")"
  cat > "$STATE_FILE" << EOF
PIPELINE=$pipeline
ID=$id
CURRENT_STEP=$current_step
STATUS=$status
TIMESTAMP=$(date -u +%Y-%m-%dT%H:%M:%SZ)
EOF
  dim "State saved: step $current_step ($status)"
}

load_state() {
  if [ ! -f "$STATE_FILE" ]; then
    error "No pipeline state found. Start a pipeline first."
    exit 1
  fi
  # shellcheck source=/dev/null
  source "$STATE_FILE"
}

clear_state() {
  rm -f "$STATE_FILE"
}

# --- User Confirmation ---
confirm() {
  local prompt="$1"
  ask "$prompt [Y/n]"
  read -r answer
  case "$answer" in
    [Nn]*) return 1 ;;
    *) return 0 ;;
  esac
}

wait_for_review() {
  local artifact="$1"
  echo ""
  info "Review the output: ${BOLD}$artifact${NC}"
  ask "Continue to next step? [Y/n/q(uit)]"
  read -r answer
  case "$answer" in
    [Nn]*) warn "Paused. Run ${BOLD}pipeline resume${NC} to continue."; exit 0 ;;
    [Qq]*) warn "Pipeline aborted."; clear_state; exit 0 ;;
    *) return 0 ;;
  esac
}

# --- Agent Runners ---
run_copilot_agent() {
  local agent="$1"
  local prompt="$2"
  header "Running: $agent (Copilot CLI)"
  dim "Prompt: $prompt"
  echo ""
  copilot --agent="$agent" -p "$prompt"
}

run_claude_agent() {
  local agent="$1"
  local prompt="$2"
  header "Running: $agent (Claude Code)"
  dim "Prompt: $prompt"
  echo ""
  claude --agent="$agent" -p "$prompt"
}

# --- Triage Loop ---
run_triage() {
  local tool="$1"  # "copilot" or "claude"
  local id="$2"
  local step_num="$3"
  local max_loops=3
  local loop=0

  while [ "$loop" -lt "$max_loops" ]; do
    echo ""
    ask "Triage findings — [F]ix / [T]ech debt / [I]gnore / [D]one? "
    read -r triage
    case "$triage" in
      [Ff]*)
        loop=$((loop + 1))
        info "Fix loop $loop/$max_loops"
        if [ "$tool" = "copilot" ]; then
          run_copilot_agent "tdd-developer" "Fix reviewer findings for Step $step_num of ${id}-todo.md"
          run_copilot_agent "qa" "Run tests after fix for Step $step_num of $id"
          run_copilot_agent "reviewer" "Re-review Step $step_num of $id after fix (loop $loop/$max_loops)"
        else
          run_claude_agent "tdd-developer" "Fix reviewer findings for Step $step_num of ${id}-todo.md"
          run_claude_agent "qa" "Run tests after fix for Step $step_num of $id"
          run_claude_agent "reviewer" "Re-review Step $step_num of $id after fix (loop $loop/$max_loops)"
        fi
        ;;
      [Tt]*)
        info "Added to tech debt in CURRENT_SPRINT.md"
        break
        ;;
      [Ii]*)
        info "Ignored."
        break
        ;;
      [Dd]*)
        break
        ;;
      *)
        warn "Invalid choice. Use F/T/I/D."
        ;;
    esac
  done

  if [ "$loop" -ge "$max_loops" ]; then
    warn "Max fix loops ($max_loops) reached. Remaining issues → tech debt."
  fi
}

# --- Count Steps ---
count_steps() {
  local todo_file="$1"
  if [ ! -f "$todo_file" ]; then
    echo "0"
    return
  fi
  grep -c '^### Step' "$todo_file" 2>/dev/null || echo "0"
}

# ╔══════════════════════════════════════════════════════════════════╗
# ║              PIPELINE 1: GITLAB FEATURE                         ║
# ╚══════════════════════════════════════════════════════════════════╝

pipeline_gitlab_feature() {
  local jira_id="$1"
  require_copilot
  require_glab

  header "Pipeline: GitLab Feature Development"
  info "Jira ticket: ${BOLD}$jira_id${NC}"
  info "Agents: Copilot CLI | Platform: GitLab"
  echo ""

  mkdir -p "$CONTEXT_DIR"

  # --- Step 1: Requirements Engineering ---
  step 1 "Requirements Engineering"
  save_state "gitlab-feature" "$jira_id" 1 "running"
  run_copilot_agent "requirements-engineer" "Analyze Jira ticket $jira_id. Create structured requirements at $CONTEXT_DIR/${jira_id}-requirements.md"
  save_state "gitlab-feature" "$jira_id" 1 "done"
  wait_for_review "$CONTEXT_DIR/${jira_id}-requirements.md"

  # --- Step 2: Test Planning ---
  step 2 "Test Planning"
  save_state "gitlab-feature" "$jira_id" 2 "running"
  run_copilot_agent "qa" "Create test plan from $CONTEXT_DIR/${jira_id}-requirements.md. Save to $CONTEXT_DIR/${jira_id}-testplan.md"
  save_state "gitlab-feature" "$jira_id" 2 "done"
  wait_for_review "$CONTEXT_DIR/${jira_id}-testplan.md"

  # --- Step 3: Architecture & Planning ---
  step 3 "Architecture & Planning"
  save_state "gitlab-feature" "$jira_id" 3 "running"
  run_copilot_agent "architect" "Design solution for $jira_id using $CONTEXT_DIR/${jira_id}-requirements.md and $CONTEXT_DIR/${jira_id}-testplan.md"
  save_state "gitlab-feature" "$jira_id" 3 "done"
  wait_for_review "$CONTEXT_DIR/${jira_id}-todo.md"

  # --- Step 4-6: TDD Loop (per step in todo) ---
  local todo_file="$CONTEXT_DIR/${jira_id}-todo.md"
  local total_steps
  total_steps=$(count_steps "$todo_file")
  info "Todo has $total_steps steps"

  for ((i = 1; i <= total_steps; i++)); do
    step "4.$i" "TDD: Implement Step $i/$total_steps"
    save_state "gitlab-feature" "$jira_id" "4.$i" "running"
    run_copilot_agent "tdd-developer" "Step $i of ${jira_id}-todo.md"
    save_state "gitlab-feature" "$jira_id" "4.$i" "dev-done"

    step "5.$i" "QA: Test Step $i/$total_steps"
    run_copilot_agent "qa" "Run tests for Step $i of $jira_id"
    save_state "gitlab-feature" "$jira_id" "5.$i" "qa-done"

    step "6.$i" "Review: Step $i/$total_steps"
    run_copilot_agent "reviewer" "Review Step $i of $jira_id"
    save_state "gitlab-feature" "$jira_id" "6.$i" "review-done"

    run_triage "copilot" "$jira_id" "$i"
  done

  # --- Step 7: Create Merge Request ---
  step 7 "Create Merge Request"
  if confirm "Create merge request on GitLab?"; then
    local branch
    branch=$(git branch --show-current)
    local base
    base=$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's@^refs/remotes/origin/@@' || echo "main")
    git push -u origin "$branch"
    glab mr create \
      --source-branch "$branch" \
      --target-branch "$base" \
      --title "feat: $jira_id" \
      --description "Closes $jira_id

## Pipeline
Generated with \`pipeline gitlab-feature $jira_id\`

## Artifacts
- Requirements: \`$CONTEXT_DIR/${jira_id}-requirements.md\`
- Test Plan: \`$CONTEXT_DIR/${jira_id}-testplan.md\`
- Spec: \`$CONTEXT_DIR/${jira_id}-spec.md\`
- Todo: \`$CONTEXT_DIR/${jira_id}-todo.md\`"
    success "Merge request created!"
  fi

  save_state "gitlab-feature" "$jira_id" 7 "complete"
  clear_state

  header "Pipeline Complete"
  success "GitLab feature pipeline for $jira_id finished."
}

# ╔══════════════════════════════════════════════════════════════════╗
# ║              PIPELINE 2: GITLAB INCIDENT                        ║
# ╚══════════════════════════════════════════════════════════════════╝

pipeline_gitlab_incident() {
  local jira_id="$1"
  require_copilot
  require_glab

  header "Pipeline: GitLab Incident Response"
  info "Jira ticket: ${BOLD}$jira_id${NC}"
  info "Agents: Copilot CLI + Troubleshooter | Platform: GitLab"
  echo ""

  mkdir -p "$CONTEXT_DIR"

  # --- Step 1: Troubleshoot ---
  step 1 "Investigation (Troubleshooter)"
  save_state "gitlab-incident" "$jira_id" 1 "running"
  run_copilot_agent "troubleshooter" "Investigate Jira incident $jira_id. Check all regions. Produce diagnosis at $CONTEXT_DIR/${jira_id}-bugfix.md"
  save_state "gitlab-incident" "$jira_id" 1 "done"

  echo ""
  info "Review diagnosis: ${BOLD}$CONTEXT_DIR/${jira_id}-bugfix.md${NC}"

  # --- Step 2: User Decision Point ---
  step 2 "Decision Point"
  echo ""
  echo -e "  ${BOLD}A${NC} — Document only (add findings to Jira, no code fix)"
  echo -e "  ${BOLD}B${NC} — Fix the issue (TDD pipeline)"
  echo -e "  ${BOLD}Q${NC} — Quit"
  echo ""
  ask "Choose action [A/B/Q]: "
  read -r decision

  case "$decision" in
    [Aa]*)
      # --- Option A: Document Only ---
      step "2A" "Adding findings to Jira"
      save_state "gitlab-incident" "$jira_id" "2A" "running"
      if [ -f "$CONTEXT_DIR/${jira_id}-bugfix.md" ]; then
        local diagnosis
        diagnosis=$(cat "$CONTEXT_DIR/${jira_id}-bugfix.md")
        # Use copilot to add the comment via Jira CLI/MCP
        run_copilot_agent "troubleshooter" "Add the diagnosis from $CONTEXT_DIR/${jira_id}-bugfix.md as a comment on Jira ticket $jira_id. Include key findings, root cause, and recommended next action."
        success "Findings added to Jira ticket $jira_id"
      else
        warn "No diagnosis file found. Add findings manually."
      fi
      save_state "gitlab-incident" "$jira_id" "2A" "complete"
      clear_state
      header "Pipeline Complete (Document Only)"
      success "Key findings documented on $jira_id."
      return
      ;;
    [Bb]*)
      info "Continuing to fix..."
      ;;
    [Qq]*)
      warn "Pipeline aborted."
      clear_state
      return
      ;;
    *)
      error "Invalid choice. Aborting."
      exit 1
      ;;
  esac

  # --- Step 3: TDD Fix ---
  local todo_file="$CONTEXT_DIR/${jira_id}-todo.md"
  local total_steps
  total_steps=$(count_steps "$todo_file")
  info "Fix plan has $total_steps steps"

  for ((i = 1; i <= total_steps; i++)); do
    step "3.$i" "TDD Fix: Step $i/$total_steps"
    save_state "gitlab-incident" "$jira_id" "3.$i" "running"
    run_copilot_agent "tdd-developer" "Step $i of ${jira_id}-todo.md"
    save_state "gitlab-incident" "$jira_id" "3.$i" "dev-done"

    step "4.$i" "QA: Verify Step $i/$total_steps"
    run_copilot_agent "qa" "Run tests for Step $i of $jira_id bugfix"
    save_state "gitlab-incident" "$jira_id" "4.$i" "qa-done"

    step "5.$i" "Review: Step $i/$total_steps"
    run_copilot_agent "reviewer" "Review Step $i of $jira_id bugfix"
    save_state "gitlab-incident" "$jira_id" "5.$i" "review-done"

    run_triage "copilot" "$jira_id" "$i"
  done

  # --- Step 6: Create MR + Update Jira ---
  step 6 "Create Merge Request"
  if confirm "Create merge request and update Jira?"; then
    local branch
    branch=$(git branch --show-current)
    local base
    base=$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's@^refs/remotes/origin/@@' || echo "main")
    git push -u origin "$branch"
    glab mr create \
      --source-branch "$branch" \
      --target-branch "$base" \
      --title "fix: $jira_id" \
      --description "Fixes $jira_id

## Root Cause
See \`$CONTEXT_DIR/${jira_id}-bugfix.md\`

## Pipeline
Generated with \`pipeline gitlab-incident $jira_id\`"
    success "Merge request created!"

    # Update Jira status
    run_copilot_agent "troubleshooter" "Transition Jira ticket $jira_id to 'In Review' and add a comment with the MR link."
  fi

  save_state "gitlab-incident" "$jira_id" 6 "complete"
  clear_state

  header "Pipeline Complete"
  success "GitLab incident pipeline for $jira_id finished."
}

# ╔══════════════════════════════════════════════════════════════════╗
# ║              PIPELINE 3: GITHUB FEATURE                         ║
# ╚══════════════════════════════════════════════════════════════════╝

pipeline_github_feature() {
  local specs_file="${1:-}"
  require_claude
  require_gh

  header "Pipeline: GitHub Feature Development"
  info "Agents: Claude Code | Platform: GitHub"

  mkdir -p "$CONTEXT_DIR"

  # --- Determine input source ---
  local req_prompt
  if [ -n "$specs_file" ] && [ -f "$specs_file" ]; then
    info "Specs file: ${BOLD}$specs_file${NC}"
    req_prompt="Read the specs file at $specs_file and create structured requirements at $CONTEXT_DIR/requirements.md"
  elif [ -f "specs.md" ]; then
    info "Specs file: ${BOLD}specs.md${NC} (auto-detected)"
    req_prompt="Read the specs file at specs.md and create structured requirements at $CONTEXT_DIR/requirements.md"
  else
    info "No specs file provided. Enter requirements interactively."
    echo ""
    ask "Describe the feature:"
    echo ""
    read -r feature_desc
    req_prompt="Create structured requirements from this description: $feature_desc. Save to $CONTEXT_DIR/requirements.md"
  fi
  echo ""

  # --- Derive an ID from timestamp for unique naming ---
  local id
  id="feature-$(date +%Y%m%d-%H%M%S)"

  # --- Step 1: Requirements Engineering ---
  step 1 "Requirements Engineering"
  save_state "github-feature" "$id" 1 "running"
  run_claude_agent "requirements-engineer" "$req_prompt"
  save_state "github-feature" "$id" 1 "done"
  wait_for_review "$CONTEXT_DIR/requirements.md"

  # --- Step 2: Create GitHub Issue ---
  step 2 "Create GitHub Issue"
  save_state "github-feature" "$id" 2 "running"

  if confirm "Create GitHub issue from requirements?"; then
    local issue_title issue_body issue_url
    # Extract a title from the requirements file
    if [ -f "$CONTEXT_DIR/requirements.md" ]; then
      issue_title=$(grep -m1 '^# ' "$CONTEXT_DIR/requirements.md" 2>/dev/null | sed 's/^# //' || echo "New feature request")
    else
      issue_title="New feature request"
    fi

    # Use claude to format and create the issue
    issue_url=$(run_claude_agent "requirements-engineer" \
      "Format $CONTEXT_DIR/requirements.md as a GitHub issue body and create it using gh issue create. The title should be: feat: $issue_title. Add the label 'feature-request'. Output ONLY the issue URL." 2>&1 | tail -1)

    if [ -n "$issue_url" ]; then
      success "GitHub issue created: $issue_url"
      # Extract issue number
      local issue_num
      issue_num=$(echo "$issue_url" | grep -oE '[0-9]+$' || echo "")
    fi
  fi

  save_state "github-feature" "$id" 2 "done"

  # --- Step 3: Architecture & Planning ---
  step 3 "Architecture & Planning"
  save_state "github-feature" "$id" 3 "running"
  run_claude_agent "architect" "Design solution using requirements from $CONTEXT_DIR/requirements.md. Create spec and todo in $CONTEXT_DIR/"
  save_state "github-feature" "$id" 3 "done"

  # Find the todo file
  local todo_file
  todo_file=$(find "$CONTEXT_DIR" -name "*-todo.md" -newer "$STATE_FILE" 2>/dev/null | head -1)
  if [ -z "$todo_file" ]; then
    todo_file=$(find "$CONTEXT_DIR" -name "*-todo.md" 2>/dev/null | sort -r | head -1)
  fi

  if [ -z "$todo_file" ]; then
    error "No todo file found in $CONTEXT_DIR. Architect may have failed."
    exit 1
  fi

  wait_for_review "$todo_file"

  # --- Step 4-6: TDD Loop ---
  local total_steps
  total_steps=$(count_steps "$todo_file")
  info "Todo has $total_steps steps"
  local todo_basename
  todo_basename=$(basename "$todo_file" .md)

  for ((i = 1; i <= total_steps; i++)); do
    step "4.$i" "TDD: Implement Step $i/$total_steps"
    save_state "github-feature" "$id" "4.$i" "running"
    run_claude_agent "tdd-developer" "Step $i of $todo_file"
    save_state "github-feature" "$id" "4.$i" "dev-done"

    step "5.$i" "QA: Test Step $i/$total_steps"
    run_claude_agent "qa" "Run tests for Step $i of $todo_basename"
    save_state "github-feature" "$id" "5.$i" "qa-done"

    step "6.$i" "Review: Step $i/$total_steps"
    run_claude_agent "reviewer" "Review Step $i of $todo_basename"
    save_state "github-feature" "$id" "6.$i" "review-done"

    run_triage "claude" "$id" "$i"
  done

  # --- Step 7: Create Pull Request ---
  step 7 "Create Pull Request"
  if confirm "Create pull request on GitHub?"; then
    local branch
    branch=$(git branch --show-current)
    local base
    base=$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's@^refs/remotes/origin/@@' || echo "main")
    git push -u origin "$branch"

    local pr_body="## Summary
Generated with \`pipeline github-feature\`

## Artifacts
- Requirements: \`$CONTEXT_DIR/requirements.md\`
- Spec: \`$CONTEXT_DIR/\`
- Todo: \`$todo_file\`"

    # Add issue reference if we have one
    if [ -n "${issue_num:-}" ]; then
      pr_body="Closes #$issue_num

$pr_body"
    fi

    gh pr create \
      --title "feat: $issue_title" \
      --body "$pr_body"

    success "Pull request created!"
  fi

  save_state "github-feature" "$id" 7 "complete"
  clear_state

  header "Pipeline Complete"
  success "GitHub feature pipeline finished."
}

# ╔══════════════════════════════════════════════════════════════════╗
# ║                       STATUS & RESUME                           ║
# ╚══════════════════════════════════════════════════════════════════╝

pipeline_status() {
  if [ ! -f "$STATE_FILE" ]; then
    info "No active pipeline."
    return
  fi

  load_state

  header "Pipeline Status"
  echo -e "  Pipeline:     ${BOLD}${PIPELINE}${NC}"
  echo -e "  ID:           ${BOLD}${ID}${NC}"
  echo -e "  Current Step: ${BOLD}${CURRENT_STEP}${NC}"
  echo -e "  Status:       ${BOLD}${STATUS}${NC}"
  echo -e "  Last Updated: ${DIM}${TIMESTAMP}${NC}"
}

pipeline_resume() {
  if [ ! -f "$STATE_FILE" ]; then
    error "No active pipeline to resume."
    exit 1
  fi

  load_state

  info "Resuming pipeline: ${BOLD}$PIPELINE${NC} for ${BOLD}$ID${NC} at step ${BOLD}$CURRENT_STEP${NC}"

  case "$PIPELINE" in
    "gitlab-feature")
      pipeline_gitlab_feature "$ID"
      ;;
    "gitlab-incident")
      pipeline_gitlab_incident "$ID"
      ;;
    "github-feature")
      pipeline_github_feature "$ID"
      ;;
    *)
      error "Unknown pipeline: $PIPELINE"
      exit 1
      ;;
  esac
}

# ╔══════════════════════════════════════════════════════════════════╗
# ║                           HELP                                  ║
# ╚══════════════════════════════════════════════════════════════════╝

show_help() {
  cat << 'HELPEOF'

  pipeline — Multi-agent pipeline runner v3.0.0

  USAGE
    pipeline <command> [arguments]

  COMMANDS
    gitlab-feature <JIRA-ID>       GitLab feature development pipeline
                                   Jira → requirements-engineer → qa (test plan)
                                   → architect → tdd-developer → qa → reviewer → MR

    gitlab-incident <JIRA-ID>      GitLab incident response pipeline
                                   Jira → troubleshooter → [document OR fix]
                                   → tdd-developer → qa → reviewer → MR

    github-feature [specs-file]    GitHub feature development pipeline
                                   specs.md/input → requirements-engineer
                                   → GitHub issue → architect → tdd-developer
                                   → qa → reviewer → PR

    status                         Show current pipeline state
    resume                         Resume pipeline from last checkpoint
    help                           Show this help

  EXAMPLES
    pipeline gitlab-feature PROJ-123
    pipeline gitlab-incident PROJ-456
    pipeline github-feature specs.md
    pipeline github-feature                  # interactive input
    pipeline status
    pipeline resume

  PREREQUISITES
    gitlab-feature:   copilot, glab, jira MCP
    gitlab-incident:  copilot, glab, az, kubectl
    github-feature:   claude, gh

HELPEOF
}

# ╔══════════════════════════════════════════════════════════════════╗
# ║                           MAIN                                  ║
# ╚══════════════════════════════════════════════════════════════════╝

main() {
  local command="${1:-help}"
  shift || true

  case "$command" in
    "gitlab-feature")
      if [ $# -lt 1 ]; then
        error "Usage: pipeline gitlab-feature <JIRA-ID>"
        exit 1
      fi
      pipeline_gitlab_feature "$1"
      ;;
    "gitlab-incident")
      if [ $# -lt 1 ]; then
        error "Usage: pipeline gitlab-incident <JIRA-ID>"
        exit 1
      fi
      pipeline_gitlab_incident "$1"
      ;;
    "github-feature")
      pipeline_github_feature "${1:-}"
      ;;
    "status")
      pipeline_status
      ;;
    "resume")
      pipeline_resume
      ;;
    "help"|"--help"|"-h")
      show_help
      ;;
    *)
      error "Unknown command: $command"
      show_help
      exit 1
      ;;
  esac
}

main "$@"
